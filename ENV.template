# Kaixu Gate Delta — ENV TEMPLATE (set these in Netlify > Site configuration > Environment variables)

# REQUIRED (your Gemini API key - stored ONLY on the gateway, never in your apps)
KAIXU_GEMINI_API_KEY="AIzaSyAucJl4z7w_rY0ekSCim7tF8Ggt7bT8R6o"

# REQUIRED (comma-separated tokens your apps must present to use the gateway)
# Example: KAIXU_APP_TOKENS=app1_token_abc,app2_token_xyz
KAIXU_APP_TOKENS="gp2awrpxZExHjvP14lFEoDHBZeBfw82Z9pTqJXEsIOI"

# REQUIRED for brain->gate service trust
# Preferred: KAIXU_SERVICE_SECRETS as comma-separated list (lets you onboard new brains without replacing old secret)
# Backward-compatible: KAIXU_SERVICE_SECRET (single value)
# Example: KAIXU_SERVICE_SECRETS="brainA_secret,brainB_secret,brainC_secret"
KAIXU_SERVICE_SECRETS=""
KAIXU_SERVICE_SECRET=""

# OPTIONAL (default model if a request doesn't specify one)
KAIXU_DEFAULT_MODEL=gemini-2.5-flash

# OPTIONAL (CORS allowlist; comma-separated exact origins)
# Example: https://skyesol.netlify.app,https://myapp.netlify.app
# If omitted, gateway will allow all origins (*).
KAIXU_ALLOWED_ORIGINS=

# OPTIONAL (set to "1" to allow unauthenticated calls — NOT recommended)
KAIXU_OPEN_GATE=0

# OPTIONAL (hard caps)
KAIXU_MAX_BODY_BYTES=5242880
KAIXU_TIMEOUT_MS=25000

# OPTIONAL (hard-coded system instruction prepended to every request)
KAIXU_GLOBAL_SYSTEM= You are kAIxu, the Skyes Over London LC AI core. Be concise, correct, and brand-neutral unless asked to be branded.

# OPTIONAL (observability)
KAIXU_LOG_LEVEL="info"


CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"

# ── Customer Self-Serve + Stripe ───────────────────────────────────────────────
# REQUIRED for customer portal + admin token DB functions
# Set either NEON_DATABASE_URL or NETLIFY_DATABASE_URL (Neon plugin-created variable)
NEON_DATABASE_URL="postgresql://..."
NETLIFY_DATABASE_URL=""

# REQUIRED: 32+ char secret for signing session JWTs (generate with: openssl rand -hex 32)
CUSTOMER_JWT_SECRET="replace-with-32-plus-char-random-secret"

# REQUIRED for Stripe billing
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # From Stripe Dashboard > Webhooks > Signing Secret

# Price IDs from your Stripe product catalogue
STRIPE_LITE_PRICE_ID="price_..."    # kAIxU Lite monthly subscription price
STRIPE_PRO_PRICE_ID="price_..."     # kAIxU Pro monthly subscription price (optional)

# REQUIRED for transactional email (magic links)
RESEND_API_KEY="re_..."             # Get from resend.com (free tier: 3,000 emails/month)
RESEND_FROM="kAIxU <noreply@yourdomain.com>"

