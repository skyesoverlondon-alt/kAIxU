# kAIxU-Brain (Skyes Over London) environment template
# Set these in Cloudflare Worker Variables/Secrets

# REQUIRED (secret)
KAIXU_OPENAI_API_KEY="sk-..."

# REQUIRED unless KAIXU_OPEN_GATE=1 (secret)
# Comma-separated app tokens accepted by this brain
KAIXU_APP_TOKENS="token_one,token_two"

# OPTIONAL brain identity label (health response)
KAIXU_BRAIN_NAME="kAIxU0s"

# Brain selector registry (no routing change yet; for controlled target selection)
# Backward compatibility: legacy target IDs core67 and coresi4 are still accepted.
# New integrations should use kaixu67 and kaixu0s.
KAIXU_BRAIN_DEFAULT_TARGET="kaixu67"
KAIXU_BRAIN_BASE_KAIXU67="https://kaixu67.skyesoverlondon.workers.dev"   # kAIxU6.7 (Delta Gate live)
KAIXU_BRAIN_BASE_KAIXU0S="https://kaixu0s.<subdomain>.workers.dev" # kAIxU0s (this brain)
KAIXU_BRAIN_BASE_FLOW32="https://skaixu-flow-32.<subdomain>.workers.dev"       # skAIxU Flow 3.2

# OPTIONAL model defaults + aliases
KAIXU_DEFAULT_MODEL="kAIxU6.7-flash"
KAIXU_EMBED_MODEL="text-embedding-3-small"

# OPTIONAL transport settings
KAIXU_OPENAI_BASE_URL="https://api.openai.com/v1"
KAIXU_TIMEOUT_MS="25000"
KAIXU_MAX_BODY_BYTES="5242880"

# OPTIONAL auth/cors behavior
KAIXU_OPEN_GATE="0"
KAIXU_ALLOWED_ORIGINS="https://yourapp.com,https://anotherapp.com"

# OPTIONAL system prepended to each generation/stream request
KAIXU_GLOBAL_SYSTEM=""

# OPTIONAL automated smoke + health cron (every 3 minutes by wrangler trigger)
# Set to "0" to disable automated smoke and keep manual-only smoke runs.
KAIXU_SMOKE_AUTORUN="1"

# OPTIONAL whether autorun includes a real provider generate ping
KAIXU_SMOKE_AUTORUN_GENERATE="1"

# OPTIONAL prompt for generate ping during cron/manual admin run
KAIXU_SMOKE_PROMPT="Reply with SMOKE_OK"
KAIXU_SMOKE_MAX_TOKENS="16"

# OPTIONAL runtime persistence for automated smoke logs (Cloudflare KV binding)
# Bind as KAIXU_SMOKE_KV in wrangler.toml
